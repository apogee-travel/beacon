{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmitOnError": false,
        "typeRoots": ["./node_modules/@types", "./node_modules/@apogeelabs/beacon"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", ".eslintrc.js", "jest.config.js"]
}
