{
    "name": "beacon-react-native-dashboard",
    "version": "1.0.0",
    "private": true,
    "main": "expo-router/entry",
    "scripts": {
        "start": "expo start",
        "android": "expo start --android",
        "ios": "expo start --ios",
        "web": "expo start --web",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch --passWithNoTests",
        "lint": "expo lint"
    },
    "dependencies": {
        "@apogeelabs/beacon": "workspace:*",
        "@apogeelabs/beacon-react-utils": "workspace:*",
        "@babel/runtime": "^7.28.6",
        "@expo/vector-icons": "^14.0.4",
        "@react-navigation/native": "^7.0.0",
        "@tanstack/react-query": "^5.74.4",
        "expo": "~52.0.46",
        "expo-constants": "~17.0.8",
        "expo-font": "~13.0.4",
        "expo-linking": "~7.0.5",
        "expo-router": "~4.0.20",
        "expo-splash-screen": "~0.29.22",
        "expo-status-bar": "~2.0.1",
        "expo-system-ui": "~4.0.7",
        "lodash": "^4.17.23",
        "mobx": "^6.13.7",
        "mobx-react-lite": "^4.1.0",
        "nativewind": "^4.1.23",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-native": "0.76.9",
        "react-native-safe-area-context": "4.12.0",
        "react-native-screens": "~4.4.0",
        "tailwindcss": "^3.4.17"
    },
    "devDependencies": {
        "@babel/core": "^7.25.2",
        "@types/jest": "^29.5.12",
        "@types/lodash": "^4.17.16",
        "@types/react": "~18.3.12",
        "@types/react-native": "^0.73.0",
        "eslint": "^9.0.0",
        "eslint-config-expo": "^55.0.0",
        "eslint-import-resolver-typescript": "^4.4.4",
        "jest": "^29.7.0",
        "jest-expo": "~52.0.5",
        "ts-jest": "^29.3.2",
        "typescript": "^5.3.3"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/src/__tests__/**/*.test.ts"
        ],
        "transform": {
            "^.+\\.tsx?$": [
                "ts-jest",
                {
                    "tsconfig": {
                        "strict": true,
                        "esModuleInterop": true,
                        "module": "commonjs",
                        "target": "es2020"
                    }
                }
            ]
        },
        "moduleNameMapper": {
            "^@apogeelabs/beacon$": "<rootDir>/../../packages/beacon/src/index.ts",
            "^@apogeelabs/beacon-react-utils$": "<rootDir>/../../packages/beacon-react-utils/src/index.ts"
        }
    }
}
