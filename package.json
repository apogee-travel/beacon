{
    "name": "beacon-monorepo",
    "version": "0.0.0",
    "private": true,
    "workspaces": [
        "packages/*",
        "examples/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "test": "turbo run test",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "turbo run build && changeset publish",
        "checks": "turbo run lint && turbo run test && turbo run build",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --config .eslintrc.js --no-warn-ignored --fix",
            "prettier --write"
        ],
        "*.{js,jsx,mjs,css,md,mdx,json}": "prettier --write"
    },
    "devDependencies": {
        "@apogeelabs/the-agency": "0.4.0",
        "@changesets/cli": "^2.26.2",
        "@eslint/js": "^9.22.0",
        "@types/jest": "^29.5.5",
        "@types/node": "^20.8.0",
        "@typescript-eslint/eslint-plugin": "^8.26.1",
        "@typescript-eslint/parser": "^8.26.1",
        "eslint-config-prettier": "^9.0.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "lint-staged": "^16.3.2",
        "prettier": "^3.0.3",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.1",
        "tsdown": "^0.20.3",
        "turbo": "^1.10.14",
        "typescript": "^5.2.2"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "unrs-resolver"
        ],
        "overrides": {
            "minimatch@<3.1.3": "3.1.3",
            "minimatch@>=5.0.0 <5.1.8": "5.1.8",
            "minimatch@>=9.0.0 <9.0.7": "9.0.7",
            "js-yaml@<3.14.2": "3.14.2",
            "js-yaml@>=4.0.0 <4.1.1": "4.1.1",
            "tmp@<=0.2.3": "0.2.4",
            "rollup": ">=4.59.0 <5"
        }
    },
    "engines": {
        "node": ">=16.0.0"
    },
    "packageManager": "pnpm@8.7.5"
}
