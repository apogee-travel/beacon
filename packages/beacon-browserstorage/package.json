{
    "name": "@apogeelabs/beacon-browserstorage",
    "author": "Apogee Travel",
    "contributors": [
        {
            "name": "Jim Cowart"
        }
    ],
    "version": "0.1.0",
    "license": "ISC",
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "keywords": [
        "beacon",
        "mobx",
        "store",
        "state management"
    ],
    "module": "dist/beacon-browserstorage.esm.js",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "typings": "dist/index.d.ts",
    "files": [
        "src"
    ],
    "engines": {
        "node": ">=16"
    },
    "scripts": {
        "start": "tsdx watch",
        "build": "tsdx build",
        "test": "jest --collect-coverage",
        "test:watch": "jest --watch --collect-coverage",
        "prepare": "tsdx build",
        "size": "size-limit",
        "analyze": "size-limit --why",
        "lint": "eslint --max-warnings 0 .",
        "prettier": "prettier -c -w .",
        "prettier-check": "prettier -c ."
    },
    "husky": {
        "hooks": {
            "pre-commit": "npm run prettier & npm run lint"
        }
    },
    "size-limit": [
        {
            "path": "dist/beacon.cjs.production.min.js",
            "limit": "10 KB"
        },
        {
            "path": "dist/beacon.esm.js",
            "limit": "10 KB"
        }
    ],
    "devDependencies": {
        "@apogeelabs/eslint-config": "^1.3",
        "@size-limit/preset-small-lib": "^11.2.0",
        "@types/jest": "29.5.12",
        "@types/jest-when": "3.5.5",
        "@types/node": "^18",
        "@typescript-eslint/eslint-plugin": "7.14.1",
        "@typescript-eslint/parser": "7.14.1",
        "eslint": "8.56.0",
        "eslint-config-prettier": "9.1.0",
        "eslint-plugin-prettier": "4.0.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "prettier": "^3.5.3",
        "size-limit": "^11.2.0",
        "ts-jest": "^29.2.6",
        "tsdx": "^0.14.1",
        "tslib": "^2.8.1",
        "typescript": "^5.8.2"
    },
    "dependencies": {
        "beacon": "^0.1.0",
        "mobx": "^6.13.6"
    }
}
