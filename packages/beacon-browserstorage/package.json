{
    "name": "@apogeelabs/beacon-browserstorage",
    "author": "Apogee Travel",
    "contributors": [
        {
            "name": "Jim Cowart"
        }
    ],
    "version": "1.0.0",
    "license": "ISC",
    "description": "Browser storage extension for beacon",
    "engines": {
        "node": ">=18"
    },
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.cts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": false,
    "scripts": {
        "dev": "tsdown --watch",
        "build": "tsdown",
        "test": "jest",
        "test:watch": "jest --watch --collect-coverage",
        "lint": "eslint --config ../../.eslintrc.js 'src/**/*.{ts,tsx}'"
    },
    "keywords": [
        "beacon",
        "mobx",
        "store",
        "localstorage",
        "sessionstorage",
        "storage"
    ],
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@apogeelabs/beacon": "workspace:*",
        "mobx": "^6.13.7"
    },
    "devDependencies": {
        "@types/jest": "^29.5.5",
        "eslint": "^8.0.1",
        "eslint-config-standard": "^17.1.0",
        "eslint-plugin-import": "^2.25.2",
        "eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
        "eslint-plugin-promise": "^6.0.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.1",
        "tsdown": "^0.20.3",
        "typescript": "^5.2.2"
    }
}
