{
  "name": "@apogeelabs/beacon-react-utils",
  "author": "Apogee Travel",
  "contributors": [
    {
      "name": "Jim Cowart"
    }
  ],
  "version": "0.3.2",
  "license": "ISC",
  "description": "beacon middleware for react-query integration with beacon stores",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "jest",
    "test:watch": "jest --watch --collect-coverage",
    "lint": "eslint --config ../../.eslintrc.js 'src/**/*.{ts,tsx}'"
  },
  "keywords": [
    "beacon",
    "mobx",
    "store",
    "state management"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@apogeelabs/beacon": "workspace:*",
    "lodash": "4.17.16",
    "mobx": "^6.13.7",
    "react": "19.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/lodash": "4.17.16",
    "@types/react": "19.1.9",
    "eslint": "^8.0.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
    "eslint-plugin-promise": "^6.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsup": "^7.2.0",
    "typescript": "^5.2.2"
  }
}
