{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "dist",
        "baseUrl": ".",
        "paths": {
            "@apogeelabs/*": ["packages/*/src"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", ".eslintrc.js", "jest.config.js"]
}
